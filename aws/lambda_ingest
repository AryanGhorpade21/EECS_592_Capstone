import json
import os
import uuid
from datetime import datetime, timezone

import boto3

# Initialize S3 client
s3 = boto3.client("s3")

# S3 bucket name passed as environment variable
BUCKET = os.environ["LOG_BUCKET"]


def _parse_timestamp(ts):
    """
    Parses incoming timestamp.
    Supports ISO 8601 (YYYY-MM-DDTHH:MM:SSZ)
    and project format (DD/MM/YYYY -- HH:MM:SS).
    Defaults to current UTC time if invalid.
    """
    if not ts or not isinstance(ts, str):
        return datetime.now(timezone.utc)

    try:
        if "T" in ts and ts.endswith("Z"):
            return datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
    except Exception:
        pass

    try:
        return datetime.strptime(ts, "%d/%m/%Y -- %H:%M:%S").replace(tzinfo=timezone.utc)
    except Exception:
        return datetime.now(timezone.utc)


def handler(event, context):
    """
    Lambda entry point.
    Receives log JSON from API Gateway,
    normalizes required fields,
    and stores record in S3 using partitioned schema.
    """

    body = event.get("body", "{}")

    # Handle base64 encoding if enabled in API Gateway
    if event.get("isBase64Encoded"):
        import base64
        body = base64.b64decode(body).decode("utf-8")

    data = json.loads(body) if isinstance(body, str) else body

    # Normalize timestamp
    ts = _parse_timestamp(data.get("timestamp"))
    iso_ts = ts.strftime("%Y-%m-%dT%H:%M:%SZ")

    # Required indexing fields 
    severity = str(data.get("severity", "INFO")).upper()
    rule_id = str(data.get("rule_id", "NONE")).upper()
    event_type = str(data.get("event_type", "metadata")).lower()

    # Final structured record stored in S3
    record = {
        "timestamp": iso_ts,
        "severity": severity,
        "rule_id": rule_id,
        "event_type": event_type,
        "original": data
    }

    # Partitioned S3 key for efficient retrieval
    key = (
        "ingested/logs/"
        f"year={ts:%Y}/month={ts:%m}/day={ts:%d}/hour={ts:%H}/"
        f"rule_id={rule_id}/severity={severity}/"
        f"{uuid.uuid4().hex}.json"
    )

    # Store encrypted object in S3
    s3.put_object(
        Bucket=BUCKET,
        Key=key,
        Body=json.dumps(record).encode("utf-8"),
        ContentType="application/json",
        ServerSideEncryption="AES256"
    )

    return {
        "statusCode": 200,
        "headers": {"Content-Type": "application/json"},
        "body": json.dumps({"ok": True, "s3_key": key})
    }
